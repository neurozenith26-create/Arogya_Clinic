# API base URL — points at our own Express backend, never directly at the DB.
VITE_API_URL=/api/v1

# Razorpay (public key only — used to open Checkout modal)
VITE_RAZORPAY_KEY_ID=rzp_test_YOUR_KEY_ID

# Mock data mode — true uses bundled fixtures so the UI works without a backend.
# Set to false once your backend is running and the DB is seeded.
VITE_USE_MOCK_DATA=true

# Feature flags
VITE_PHASE_2_ENABLED=true
