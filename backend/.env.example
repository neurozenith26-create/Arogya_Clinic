# ─── Server ────────────────────────────────────────────────────────────
PORT=3001
NODE_ENV=development
TZ=Asia/Kolkata
LOG_LEVEL=info
CORS_ORIGIN=http://localhost:5173

# ─── Database ──────────────────────────────────────────────────────────
# A standard Postgres connection string. Works with ANY Postgres provider:
# Supabase, Neon, Render, Railway, AWS RDS, self-hosted, local docker, etc.
# Swap providers by changing this URL — no other code change needed.
DATABASE_URL=postgresql://postgres:password@localhost:5432/arogya
DATABASE_SSL=false

# ─── Auth ──────────────────────────────────────────────────────────────
# JWT signing secret — generate a random 64+ char string for production:
#   node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=replace-this-with-a-long-random-string-in-production
JWT_EXPIRES_IN=7d
BCRYPT_ROUNDS=10
OTP_EXPIRY_MINUTES=10
OTP_MAX_ATTEMPTS=5

# ─── File storage ──────────────────────────────────────────────────────
# Patient + admin file uploads (reports, payment proofs, photos) live in
# Postgres as BYTEA (see migrations 0022, 0024, 0027). No external object
# store is needed. These three vars only configure the legacy local-disk
# storage adapter, which is now unused by app code but kept for future
# providers (S3, etc).
STORAGE_DRIVER=local
STORAGE_LOCAL_PATH=./uploads
STORAGE_PUBLIC_BASE_URL=http://localhost:3001/uploads

# Absolute public origin of THIS backend. Report file URLs are built as
# ${BACKEND_PUBLIC_URL}/api/v1/files/<key>, so the frontend can use them
# directly as <img src> / <a href> across origins (Netlify → Render).
# Local dev: http://localhost:3001  ·  Render: https://<service>.onrender.com
BACKEND_PUBLIC_URL=http://localhost:3001

# ─── Payments — Razorpay (Phase 2, optional in dev) ────────────────────
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
RAZORPAY_WEBHOOK_SECRET=

# ─── Email — Resend (Phase 2, optional in dev) ─────────────────────────
RESEND_API_KEY=
EMAIL_FROM=noreply@arogyaclinic.in

# ─── SMS — MSG91 (Phase 2, optional in dev) ────────────────────────────
MSG91_AUTH_KEY=
MSG91_SENDER_ID=AROGYA
MSG91_OTP_TEMPLATE_ID=
MSG91_BOOKING_TEMPLATE_ID=
MSG91_REPORT_READY_TEMPLATE_ID=

# ─── Error reporting (optional) ────────────────────────────────────────
SENTRY_DSN=
